---
import { APP_URL, GITHUB_URL } from "../config";
import WaveMark from "./WaveMark.astro";
---

<!-- FINAL CTA -->
<section class="wrap">
  <div class="final">
    <WaveMark size={64} style="display:block;margin:0 auto 22px" />
    <h2 class="serif">You've been guessing.<br><em>You don't have to.</em></h2>
    <p>Connect your accounts and see your next move in about five minutes. It's free to start and open source.</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={APP_URL}>Get started →</a>
      <a class="btn btn-ghost" href={GITHUB_URL}>View the source →</a>
    </div>
  </div>
</section>
