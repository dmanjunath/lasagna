---
import { APP_URL, GITHUB_URL } from "../config";

const layers = [
  { idx: "01", label: "Stabilize + oh-shit fund", val: "$1,000 · done", cls: "l1" },
  { idx: "02", label: "Employer match", val: "capturing 100%", cls: "l2" },
  { idx: "03", label: "High-rate debt", val: "$0 · paid off", cls: "l3" },
  { idx: "04", label: "Emergency fund", val: "$24,000 / $24,000", cls: "l4" },
  { idx: "05", label: "Insurance and will", val: "← you are here", cls: "l5" },
  { idx: "06", label: "Tax-advantaged investing", val: "$4,200 / $7,000", cls: "l6" },
];
---

<section class="hero">
  <div class="hero-text">
    <div class="eyebrow" style="margin-bottom: 20px;">Personal finance, layered</div>
    <h1 class="serif">
      Your money.<br />
      Your <em>privacy</em>.<br />
      Your AI.
    </h1>
    <p class="hero-sub">
      LasagnaFi is a personal financial dashboard with a private AI advisor. Ask anything about your money. The AI sees your numbers and patterns, never your name, bank, or account details.
    </p>
    <div class="hero-cta">
      <a href={GITHUB_URL} class="btn btn-primary">View on GitHub →</a>
      <a href="#privacy" class="btn btn-ghost">See how privacy works</a>
      <p style="font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 8px; width: 100%;">Hosted version coming soon</p>
    </div>
    <div class="hero-meta">
      <span>No data brokers, ever</span>
      <span>AI sees numbers, not names</span>
      <span>Open source</span>
    </div>
  </div>

  <div class="stack-viz">
    {layers.map((l) => (
      <div class={`stack-layer ${l.cls}`}>
        <div class="layer-left">
          <span class="idx">{l.idx}</span>
          <span class="lbl">{l.label}</span>
        </div>
        <span class="val">{l.val}</span>
      </div>
    ))}
    <div class="stack-caption">FIG. 01 // YOUR PERSONAL FINANCIAL LAYERS</div>
  </div>
</section>

<style>
  .hero {
    max-width: 1240px;
    margin: 0 auto;
    padding: 80px 32px 64px;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  h1 {
    font-size: clamp(54px, 6.5vw, 96px);
    line-height: 0.98;
    letter-spacing: -0.022em;
    font-weight: 400;
  }

  h1 em {
    font-style: italic;
    color: var(--sauce);
  }

  .hero-sub {
    margin-top: 24px;
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 500px;
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .hero-meta {
    margin-top: 28px;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }

  .hero-meta span::before {
    content: "· ";
    color: var(--sauce);
  }

  /* Stack viz */
  .stack-viz {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 28px 0;
  }

  .stack-layer {
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 12px 24px -16px rgba(31,26,22,0.3);
    transform-origin: left center;
    transition: transform 0.25s ease;
    cursor: default;
  }

  .stack-layer:hover { transform: translateX(6px); }

  .layer-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .idx {
    font-family: var(--mono);
    font-size: 10px;
    opacity: 0.65;
  }

  .lbl { font-size: 13px; font-weight: 500; }
  .val { font-family: var(--mono); font-size: 12px; font-variant-numeric: tabular-nums; }

  /* Layer colors — red to green gradient */
  .l1 { background: #B83B3B; color: #fff; width: 94%; }
  .l2 { background: #C25030; color: #fff; width: 88%; margin-left: 6%; }
  .l3 { background: #C46425; color: #fff; width: 92%; margin-left: 2%; }
  .l4 { background: #B87A1E; color: #fff; width: 86%; margin-left: 8%; }
  .l5 { background: #8B7A22; color: #fff; width: 90%; margin-left: 4%; }
  .l6 { background: #5E7A28; color: #fff; width: 96%; }

  .stack-caption {
    position: absolute;
    bottom: -2px;
    left: 0;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 48px 20px 48px;
      gap: 40px;
    }
    .stack-viz { display: none; }
  }
</style>
