---
import { APP_URL, GITHUB_URL } from "../config";

const managedFeatures = [
  "We host your Postgres vault — encrypted at rest",
  "Plaid connections included, unlimited accounts",
  "Managed updates and backups",
  "Your own Claude API key for AI (BYOK)",
  "Export everything, any time, zero lock-in",
  "Cancel and take your database with you",
];

const selfFeatures = [
  "Run on your server, your NAS, or a Raspberry Pi",
  "Docker image — one command to boot",
  "Bring your own Plaid keys (or enter manually)",
  "Every feature, zero gating",
  "Optional $49/yr for priority support",
  "Source available on GitHub",
];
---

<section id="pricing">
  <div class="inner">
    <div class="section-head">
      <h2 class="serif">Two ways to run it.<br /><em>Same privacy model.</em></h2>
      <p>Whether we host it for you or you host it yourself, your data never leaves your vault and the AI only sees anonymized context.</p>
    </div>

    <div class="pricing-grid">
      <!-- Managed / Hosted -->
      <div class="plan plan-hosted">
        <div class="eyebrow">Hosted</div>
        <h3 class="serif">Managed</h3>
        <div class="price serif">$9<small>/ month</small></div>
        <ul>
          {managedFeatures.map((f) => <li>{f}</li>)}
        </ul>
        <a href={`${APP_URL}/login`} class="btn btn-primary cta-btn">Start 30-day trial →</a>
      </div>

      <!-- Self-hosted / Sovereign -->
      <div class="plan plan-self">
        <div class="eyebrow" style="color: var(--cheese);">Self-hosted</div>
        <h3 class="serif">Sovereign</h3>
        <div class="price serif">Free<small>forever · open source</small></div>
        <ul>
          {selfFeatures.map((f) => <li>{f}</li>)}
        </ul>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="btn btn-cheese cta-btn">View on GitHub →</a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    border-top: 1px solid var(--rule);
  }

  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 96px 32px;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    gap: 32px;
    flex-wrap: wrap;
  }

  h2 {
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  h2 em { font-style: italic; color: var(--sauce); }

  .section-head p {
    max-width: 360px;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .plan {
    border: 1px solid var(--rule);
    border-radius: 20px;
    padding: 36px;
    position: relative;
  }

  .plan-hosted {
    background: var(--cream);
  }

  .plan-self {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .plan .eyebrow {
    margin-bottom: 8px;
  }

  h3 {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: 8px;
  }

  .price {
    font-family: var(--serif);
    font-size: 52px;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 28px;
  }

  .price small {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--muted);
    margin-left: 6px;
    font-weight: 400;
  }

  .plan-self .price small { color: #9a8d77; }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 28px 0;
  }

  li {
    padding: 10px 0;
    border-bottom: 1px solid var(--rule);
    font-size: 14px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  li::before {
    content: "✓";
    color: var(--sauce);
    font-family: var(--mono);
    flex-shrink: 0;
  }

  .plan-self li { border-bottom-color: #3A322C; color: #D4C6B0; }
  .plan-self li::before { color: var(--cheese); }

  .cta-btn {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 700px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .inner { padding: 64px 20px; }
  }
</style>
