---
const steps = [
  {
    num: "01",
    title: "Your data in your vault",
    desc: "Connect via Plaid or enter balances manually. Accounts, holdings, and transactions live in your private Postgres — on your server or ours.",
  },
  {
    num: "02",
    title: "Ask a plain question",
    desc: '"Am I saving enough?" or "Pay down debt or invest?" LasagnaFi assembles the relevant context from your database.',
  },
  {
    num: "03",
    title: "Context is anonymized",
    desc: "Identifying fields are stripped before the request leaves your machine. The model sees balances, allocations, and spending patterns.",
  },
  {
    num: "04",
    title: "Advice from real numbers",
    desc: "Get personalized, actionable answers — drill down, follow up, run projections. Nothing is retained between sessions.",
  },
];
---

<section id="how">
  <div class="inner">
    <div class="section-head">
      <h2 class="serif">Four steps. <em>Nothing hidden.</em></h2>
      <p>A simple loop: connect accounts, ask a question, see the scrubbed context, get an answer built from your real numbers.</p>
    </div>

    <div class="steps">
      {steps.map((s) => (
        <div class="step">
          <div class="num">{s.num}</div>
          <h3 class="serif">{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    border-top: 1px solid var(--rule);
  }

  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 96px 32px;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    gap: 32px;
    flex-wrap: wrap;
  }

  h2 {
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  h2 em { font-style: italic; color: var(--sauce); }

  .section-head p {
    max-width: 360px;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--rule);
  }

  .step {
    padding: 32px 24px 32px 0;
    border-right: 1px solid var(--rule);
  }

  .step:last-child { border-right: 0; }

  .num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--sauce);
    letter-spacing: 0.14em;
    margin-bottom: 14px;
  }

  h3 {
    font-size: 24px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
    font-weight: 400;
  }

  p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 860px) {
    .steps { grid-template-columns: 1fr 1fr; }
    .step { border-right: 0; border-bottom: 1px solid var(--rule); padding: 24px 0; }
    .step:nth-child(odd) { padding-right: 16px; }
    .inner { padding: 64px 20px; }
  }

  @media (max-width: 540px) {
    .steps { grid-template-columns: 1fr; }
  }
</style>
