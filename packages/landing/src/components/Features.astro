---
const features = [
  {
    title: "Data that never trains a model",
    description:
      "Your financial data is stored in your database — not in a model's training set. You bring your own API key; Anthropic sees your queries under their standard API terms, but Lasagna never does.",
    svg: `<svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 2L3 5v5c0 4.4 3 8.5 7 9.5 4-1 7-5.1 7-9.5V5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: "Anonymous context, real answers",
    description:
      "When you ask the AI a question, Lasagna sends numbers and patterns — never your name, account numbers, or institution details. The model advises your finances without knowing whose they are.",
    svg: `<svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
      <path d="M7.5 10c0-1.4 1.1-2.5 2.5-2.5s2.5 1.1 2.5 2.5-1.1 2.5-2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="4.5" y1="4.5" x2="15.5" y2="15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: "The full picture",
    description:
      "Accounts, holdings, retirement projections, Monte Carlo simulations, tax strategy, debt, and spending — all in one place, connected, so the AI always has complete context.",
    svg: `<svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 14l4-5 4 3 3-4 3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="2" y="2" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
    </svg>`,
  },
];
---

<section class="relative border-t border-white/[0.06] px-6 pb-24 pt-20" style="background: linear-gradient(to bottom, rgb(12,12,18) 0%, rgb(8,8,12) 100%);">
  <div class="mx-auto max-w-5xl">
    <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.15em] text-[rgb(0,229,160)]">
      Why Lasagna
    </p>
    <h2 class="mb-16 text-2xl font-bold tracking-[-0.02em] text-[rgb(228,228,240)] sm:text-3xl">
      Built around your privacy,<br class="hidden sm:block" />
      not around your data.
    </h2>

    <div class="grid gap-px border border-white/[0.06] sm:grid-cols-3" style="background: rgba(255,255,255,0.04);">
      {
        features.map((f, i) => (
          <div class={`bg-[rgb(11,11,17)] p-8 ${i < 2 ? "sm:border-r border-white/[0.06]" : ""}`}>
            <div class="mb-5 text-[rgb(148,160,176)]" set:html={f.svg} />
            <h3 class="mb-3 text-[15px] font-semibold text-[rgb(228,228,240)]">{f.title}</h3>
            <p class="text-sm leading-relaxed text-[rgb(90,96,112)]">{f.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
