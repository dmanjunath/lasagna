---
const features = [
  {
    num: "01",
    category: "Dashboard",
    title: "Net worth at a glance.",
    desc: "30-day sparkline, cash, spending, goals, and AI-generated action items. The whole picture on one page.",
  },
  {
    num: "02",
    category: "Retirement",
    title: "FIRE math you can feel.",
    desc: "Age and spending sliders, projection charts, readiness meter. Numbers pulled live from your accounts.",
  },
  {
    num: "03",
    category: "Monte Carlo",
    title: "10,000 futures, one plan.",
    desc: "Stochastic sims, fan charts, historical backtests against every market period since 1928.",
  },
  {
    num: "04",
    category: "Portfolio",
    title: "Every holding, classified.",
    desc: "Aggregate across accounts, drill by asset class. 175+ tickers mapped to categories with blended historical returns.",
  },
  {
    num: "05",
    category: "Tax Strategy",
    title: "Optimizations you'd miss.",
    desc: "Roth conversions, 0% LTCG harvesting, HSA, asset location, 401(k) gap analysis. AI-generated and reviewable.",
  },
  {
    num: "06",
    category: "AI Chat",
    title: "AI that actually knows you.",
    desc: "12 specialized financial tools. The AI can read your accounts, run projections, and recommend moves. All on your real numbers.",
  },
];
---

<section id="features">
  <div class="inner">
    <div class="section-head">
      <h2 class="serif">Everything you expect,<br /><em>nothing you don't.</em></h2>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <div class="feat">
          <div class="eyebrow">{f.num} · {f.category}</div>
          <h4 class="serif">{f.title}</h4>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    border-top: 1px solid var(--rule);
  }

  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 96px 32px;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    gap: 32px;
    flex-wrap: wrap;
  }

  h2 {
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  h2 em { font-style: italic; color: var(--sauce); }

  .section-head p {
    max-width: 360px;
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.6;
    margin: 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    border-radius: 16px;
    overflow: hidden;
  }

  .feat {
    background: var(--paper);
    padding: 28px;
  }

  .feat .eyebrow {
    color: var(--sauce);
    margin-bottom: 12px;
  }

  h4 {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }

  p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 860px) {
    .features-grid { grid-template-columns: 1fr 1fr; }
    .inner { padding: 64px 20px; }
  }

  @media (max-width: 540px) {
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
