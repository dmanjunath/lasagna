---
---

<section class="io-section" id="inputs-outputs">
  <div class="inner">
    <div class="section-head">
      <h2 class="serif">
        Feed it everything.<br /><em>Get back what to do.</em>
      </h2>
      <p>
        LasagnaFi takes the full picture — your income, accounts, debts, taxes, and goals — and turns it into a short list of actions worth your attention. Not charts. Not categories. Decisions.
      </p>
    </div>

    <div class="io-diagram">
      <!-- INPUTS column -->
      <div class="io-col io-col-inputs">
        <div class="io-col-cap">
          <span class="eyebrow">Inputs · what you feed in</span>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5" r="2.4" stroke="currentColor" stroke-width="1.3"/><path d="M3 13c.6-2.6 2.6-4 5-4s4.4 1.4 5 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Residency</div><div class="io-detail">State · filing status · dependents</div></div>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2.5 4h11M2.5 8h11M2.5 12h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Tax info</div><div class="io-detail">W-2 · 1099 · prior returns · brackets</div></div>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 12h12M4 12V8M7 12V5M10 12V9M13 12V6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Income</div><div class="io-detail">Salary · bonus · side · K-1 · rental</div></div>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="4" width="12" height="9" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M2 7h12M5 10h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Spending</div><div class="io-detail">Plaid feed · 6mo trend · categories</div></div>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 13V6l5-3 5 3v7M6 13V9h4v4" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg></span>
          <div><div class="io-name">Debt</div><div class="io-detail">APRs · balances · minimums · payoff dates</div></div>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 2.5V8l3.5 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Investments</div><div class="io-detail">Holdings · 175+ tickers · IRA · 401(k)</div></div>
        </div>
        <div class="io-card">
          <span class="io-icon" data-color="basil"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.3"/><circle cx="8" cy="8" r="2" fill="currentColor"/></svg></span>
          <div><div class="io-name">Goals</div><div class="io-detail">FIRE · house · sabbatical · timeline</div></div>
        </div>
      </div>

      <!-- ARROW + CORE -->
      <div class="io-arrow-wrap">
        <div class="io-flow-arrow">
          <span class="dotline"></span>
          <span class="arrowhead">&#9654;</span>
        </div>
      </div>

      <div class="io-core">
        <span class="eyebrow">Lasagna<em style="font-style: italic; color: var(--sauce);">Fi</em></span>
        <div class="io-core-mark">
          <span class="mark xl"><i></i><i></i><i></i><i></i><i></i></span>
        </div>
        <div class="io-core-tag serif">layered<br />analysis</div>
        <div class="io-core-list">
          <div class="io-core-step"><span class="io-step-pip"></span>contextualize</div>
          <div class="io-core-step"><span class="io-step-pip"></span>simulate</div>
          <div class="io-core-step"><span class="io-step-pip"></span>compare</div>
          <div class="io-core-step"><span class="io-step-pip"></span>surface</div>
        </div>
      </div>

      <div class="io-arrow-wrap">
        <div class="io-flow-arrow">
          <span class="dotline"></span>
          <span class="arrowhead">&#9654;</span>
        </div>
      </div>

      <!-- OUTPUTS column -->
      <div class="io-col io-col-outputs">
        <div class="io-col-cap">
          <span class="eyebrow" style="color: var(--sauce-deep);">Outputs · what you get back</span>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2.5 4h11M2.5 8h11M2.5 12h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Tax moves</div><div class="io-detail">Potential Roth conversions, harvesting windows</div></div>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 13l4-4 3 3 5-6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 6h4v4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Investment insights</div><div class="io-detail">Asset location, allocation analysis</div></div>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.3"/><path d="M8 2.5V8l3.5 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Retirement projections</div><div class="io-detail">Monte Carlo scenarios, target ranges</div></div>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="4" width="12" height="9" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M2 7h12M5 10h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Spending patterns</div><div class="io-detail">Trends, category shifts, anomalies</div></div>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 13V6l5-3 5 3v7M6 13V9h4v4" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg></span>
          <div><div class="io-name">Debt strategy</div><div class="io-detail">Avalanche vs snowball comparison</div></div>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.3"/><circle cx="8" cy="8" r="2" fill="currentColor"/></svg></span>
          <div><div class="io-name">Goal pacing</div><div class="io-detail">On track / behind / timeline estimates</div></div>
        </div>
        <div class="io-card out">
          <span class="io-icon" data-color="cheese"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v3M8 11v3M2 8h3M11 8h3M4 4l2 2M10 10l2 2M4 12l2-2M10 6l2-2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
          <div><div class="io-name">Action items</div><div class="io-detail">Prioritized · grouped by urgency</div></div>
        </div>
      </div>
    </div>

    <div class="io-footnote">
      <span class="mono">FIG. 02 ·</span>
      <span class="mono">12 financial tools · 175+ tickers · Monte Carlo across every market period since 1928</span>
    </div>
  </div>
</section>

<style>
  .io-section {
    background: var(--paper);
    color: var(--ink);
    position: relative;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .io-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px circle at 90% 10%, color-mix(in oklab, var(--cheese) 18%, transparent), transparent 55%),
      repeating-linear-gradient(135deg, transparent 0 14px, rgba(31,26,22,0.018) 14px 15px);
    pointer-events: none;
  }

  .inner { max-width: 1240px; margin: 0 auto; padding: 96px 32px; position: relative; }

  .section-head {
    margin-bottom: 56px;
  }

  .section-head h2 { color: var(--ink); }
  .section-head h2 em { color: var(--sauce); }
  .section-head p { color: var(--ink-soft); max-width: 600px; font-size: 15px; line-height: 1.6; margin: 16px 0 0; }

  h2 {
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  .io-diagram {
    display: grid;
    grid-template-columns: 1fr 40px 1.05fr 40px 1fr;
    gap: 14px;
    align-items: stretch;
  }

  .io-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .io-col-cap { margin-bottom: 6px; }

  .io-card {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 12px;
    align-items: center;
    padding: 12px 14px;
    border: 1px solid var(--rule);
    border-radius: 10px;
    background: var(--paper);
  }

  .io-card.out {
    background: color-mix(in oklab, var(--cheese) 12%, var(--paper));
    border-color: color-mix(in oklab, var(--cheese) 35%, var(--rule));
  }

  .io-icon {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--cream);
    border: 1px solid var(--rule);
  }

  .io-icon[data-color="basil"] { color: var(--basil); }
  .io-icon[data-color="cheese"] { color: var(--sauce-deep); }

  .io-name {
    color: var(--ink);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 2px;
  }

  .io-detail {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    line-height: 1.35;
  }

  .io-arrow-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .io-flow-arrow {
    display: flex;
    align-items: center;
    width: 100%;
    color: var(--sauce);
  }

  .io-flow-arrow .dotline {
    flex: 1;
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--sauce) 0 4px, transparent 4px 8px);
    opacity: 0.8;
  }

  .io-flow-arrow .arrowhead {
    font-size: 14px;
    margin-left: 3px;
    filter: drop-shadow(0 0 6px color-mix(in oklab, var(--sauce) 60%, transparent));
  }

  .io-core {
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 24px 20px;
    background: linear-gradient(180deg, var(--paper), var(--cream));
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }

  .io-core::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(45deg, transparent 0 6px, rgba(201,84,58,0.04) 6px 7px);
    pointer-events: none;
  }

  .io-core-mark .mark.xl {
    width: 90px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .io-core-mark .mark.xl i {
    height: 10px;
    border-radius: 2px;
    display: block;
  }

  .io-core-mark .mark.xl i:nth-child(1) { background: var(--sauce);  width: 100%; }
  .io-core-mark .mark.xl i:nth-child(2) { background: var(--cheese); width: 78%; }
  .io-core-mark .mark.xl i:nth-child(3) { background: var(--noodle); width: 92%; }
  .io-core-mark .mark.xl i:nth-child(4) { background: var(--cheese); width: 70%; }
  .io-core-mark .mark.xl i:nth-child(5) { background: var(--basil);  width: 88%; }

  .io-core-tag {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--sauce);
    line-height: 1.1;
  }

  .io-core-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: left;
    width: 100%;
  }

  .io-core-step {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  .io-step-pip {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--basil);
    flex-shrink: 0;
  }

  .io-core-step:nth-child(2) .io-step-pip { background: var(--cheese); }
  .io-core-step:nth-child(3) .io-step-pip { background: var(--noodle); }
  .io-core-step:nth-child(4) .io-step-pip { background: var(--sauce); }

  .io-footnote {
    margin-top: 26px;
    padding-top: 18px;
    border-top: 1px dashed var(--rule);
    font-family: var(--mono);
    font-size: 11px;
    display: flex;
    gap: 8px;
  }

  .io-footnote span:first-child { color: var(--muted); }
  .io-footnote span:last-child { color: var(--sauce-deep); }

  @media (max-width: 1040px) {
    .io-diagram {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .io-arrow-wrap {
      height: 28px;
      width: 60px;
      margin: 0 auto;
      transform: rotate(90deg);
      transform-origin: center;
    }

    .io-flow-arrow { width: 60px; }
  }

  @media (max-width: 540px) {
    .inner { padding: 64px 20px; }
  }
</style>
