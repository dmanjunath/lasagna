---
---

<section class="privacy" id="privacy">
  <div class="inner">
    <div class="section-head">
      <h2 class="serif">
        Most finance apps sell your data.<br /><em>LasagnaFi scrubs it.</em>
      </h2>
      <p>
        Before any question reaches the AI, identifying information is stripped. The model sees balances and patterns, not your name, institution, or account numbers.
      </p>
    </div>

    <div class="diagram">
      <!-- Your vault -->
      <div class="vault">
        <div class="vault-title">
          <span class="eyebrow" style="color: var(--cheese);">Your data</span>
          <span class="dot dot-basil"></span>
        </div>
        <ul>
          <li><span class="k">holder</span><span class="v">Jane Richter</span></li>
          <li><span class="k">bank</span><span class="v">First National</span></li>
          <li><span class="k">acct ****</span><span class="v">9821</span></li>
          <li><span class="k">balance</span><span class="v">$48,230.14</span></li>
          <li><span class="k">savings rate</span><span class="v">22.4%</span></li>
          <li><span class="k">portfolio β</span><span class="v">0.87</span></li>
        </ul>
      </div>

      <div class="arrow">→</div>

      <!-- Scrub layer -->
      <div class="scrub">
        <span class="eyebrow" style="color: var(--cheese); display: block; margin-bottom: 8px;">Scrub layer</span>
        <div class="scrub-sign serif">anonymize</div>
        <p class="scrub-desc">Names, institutions, and account identifiers are replaced with tokens. Numbers and ratios pass through.</p>
      </div>

      <div class="arrow">→</div>

      <!-- Sent to AI -->
      <div class="vault">
        <div class="vault-title">
          <span class="eyebrow" style="color: var(--cheese);">Sent to AI</span>
          <span class="dot dot-cheese"></span>
        </div>
        <ul>
          <li><span class="k">holder</span><span class="v">user_0xA2</span></li>
          <li><span class="k">bank</span><span class="v">[redacted]</span></li>
          <li><span class="k">acct</span><span class="v">acct_01</span></li>
          <li><span class="k">balance</span><span class="v">$48,230.14</span></li>
          <li><span class="k">savings rate</span><span class="v">22.4%</span></li>
          <li><span class="k">portfolio β</span><span class="v">0.87</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .privacy {
    background: var(--ink);
    color: var(--paper);
  }

  .inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 100px 32px;
  }

  .section-head {
    margin-bottom: 64px;
  }

  h2 {
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
  }

  h2 em {
    font-style: italic;
    color: var(--cheese);
  }

  .section-head p {
    max-width: 600px;
    color: #D4C6B0;
    font-size: 15px;
    line-height: 1.6;
    margin: 16px 0 0;
  }

  .diagram {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 20px;
    align-items: stretch;
  }

  .vault {
    border: 1px solid #3A322C;
    border-radius: 14px;
    padding: 22px;
    background: #26201C;
  }

  .vault-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot-basil {
    background: var(--basil);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--basil) 30%, transparent);
  }

  .dot-cheese {
    background: var(--cheese);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--cheese) 30%, transparent);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--mono);
    font-size: 12px;
  }

  li {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px dashed #3A322C;
    color: #D4C6B0;
  }

  li:last-child { border-bottom: 0; }

  .k { color: #9a8d77; }
  .v { color: var(--paper); }

  .arrow {
    font-family: var(--mono);
    font-size: 22px;
    color: var(--cheese);
    align-self: center;
    text-align: center;
    flex-shrink: 0;
  }

  .scrub {
    border: 1px solid #3A322C;
    border-radius: 14px;
    padding: 24px;
    background: linear-gradient(180deg, #1F1A16, #26201C);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .scrub-sign {
    font-size: 36px;
    font-style: italic;
    color: var(--sauce);
    margin: 12px 0;
    font-family: var(--serif);
  }

  .scrub-desc {
    font-size: 13px;
    color: #D4C6B0;
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 860px) {
    .diagram {
      grid-template-columns: 1fr;
    }
    .arrow {
      transform: rotate(90deg);
    }
    .inner { padding: 64px 20px; }
  }
</style>
