---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LasagnaFi // Private AI-Powered Personal Finance",
  description = "LasagnaFi connects your accounts, runs retirement simulations, and answers financial questions with AI. Your data stays private. The AI sees numbers and patterns, never your name, bank, or account details.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>document.documentElement.classList.add("js");</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Same faces as the app: Bricolage Grotesque (display) + Plus Jakarta Sans (body) + JetBrains Mono (figures) -->
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
