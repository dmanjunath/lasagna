# Database
DATABASE_URL=postgresql://lasagna:lasagna@localhost:5432/lasagna

# Encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Multi-tenancy — true (default) isolates each user and never grants admin on signup.
# Set to false only for a single-tenant/internal deployment where every new user
# should be internal and receive admin access.
MULTI_TENANT=true

# Server
PORT=3000

# Sync schedule (cron expression)
SYNC_CRON=0 */4 * * *

# OpenRouter (for AI agent)
OPENROUTER_API_KEY=

# sailresearch.com inference (OpenAI-compatible alternative to OpenRouter).
# Set SAIL_RESEARCH_API_KEY to route inference through sail instead of OpenRouter.
# INFERENCE_PROVIDER (openrouter|sail) overrides selection; if unset, sail is used
# automatically when SAIL_RESEARCH_API_KEY is present.
SAIL_RESEARCH_API_KEY=
INFERENCE_PROVIDER=

# Environment label sent to OpenRouter as X-OpenRouter-Title ("LasagnaFi <APP_ENV>"). Defaults to NODE_ENV or "dev".
APP_ENV=dev

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
APP_URL=http://localhost:5173

# WorkOS (optional). When BOTH are set, auth uses WorkOS (email/password + Sign in with Google,
# email verification, password reset). When either is blank, the app falls back to local
# email/password only (no Google) — fine for self-hosting without a WorkOS account.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Optional; defaults to ${APP_URL}/api/auth/google/callback. Must be registered as an allowed
# redirect URI on the WorkOS AuthKit application.
WORKOS_REDIRECT_URI=

# Google Maps — server-side key for the Places address-autocomplete proxy
# (/api/places/*). Kept off the client. Needs the "Places API (New)" enabled
# on the Google Cloud project.
GOOGLE_MAPS_API_KEY=

# Real-estate value estimates
# URL is the datasets base (ends with /datasets/v3),
# KEY is the Bearer token, DATASET_ID selects the property dataset.
REAL_ESTATE_VALUES_API_URL=
REAL_ESTATE_VALUES_API_KEY=
REAL_ESTATE_VALUES_DATASET_ID=
