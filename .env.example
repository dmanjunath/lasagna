# Database
DATABASE_URL=postgresql://lasagna:lasagna@localhost:5432/lasagna

# Encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Multi-tenancy — set to true for paid multi-tenant mode
MULTI_TENANT=false

# Server
PORT=3000

# Sync schedule (cron expression)
SYNC_CRON=0 */4 * * *

# OpenRouter (for AI agent)
OPENROUTER_API_KEY=
